/* ─── TOKENS ─────────────────────────────────────────────── */
:root {
  --orange: #EF8354;
  --orange-deep: #9A3412;
  --cream: #FAF7F2;
  --cream-2: #E8DDD0;
  --cream-warm: #F9EDDD;
  --dark: #1C1C2E;
  --dark-2: #20405e;
  --text: #2d2d2d;
  --muted: #555555;
  --white: #FFFFFF;
  --serif: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
  --sans: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Arial, sans-serif;
  --radius: 4px;
  --max: 1440px;
  --pad-x: clamp(2rem, 5vw, 7rem);
}

/* ─── RESET ──────────────────────────────────────────────── */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
  font-size: 17px;
  overflow-x: hidden;
}

body {
  font-family: var(--sans);
  background: var(--cream);
  color: var(--text);
  overflow-x: hidden;
}

img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

a {
  text-decoration: none;
  color: inherit;
}

em { font-style: normal; }
ul { list-style: none; }

button, input, select, textarea {
  font-family: inherit;
}

/* ─── UTILITY ─────────────────────────────────────────────── */
.container {
  max-width: var(--max);
  margin: 0 auto;
  padding: 0 var(--pad-x);
}

.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
}

/* ─── BUTTONS ─────────────────────────────────────────────── */
.btn {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  padding: .7rem 1.6rem;
  border-radius: 99px;
  font-size: .9rem;
  font-weight: 500;
  letter-spacing: .02em;
  cursor: pointer;
  border: none;
  transition: opacity .2s, transform .15s;
}

.btn:hover {
  opacity: .85;
  transform: translateY(-1px);
}

.btn-dark {
  background: #162933;
  color: var(--white);
}

.btn-outline {
  background: transparent;
  color: var(--dark);
  border: 1.5px solid var(--dark);
}

.btn-orange {
  background: var(--orange);
  color: var(--white);
}

.btn-orange-outline {
  background: transparent;
  color: var(--orange);
  border: 1.5px solid var(--orange);
}

.btn-dark-solid {
  background: var(--dark);
  color: var(--white);
  border-radius: var(--radius);
  padding: .75rem 1.6rem;
  font-size: .85rem;
  font-weight: 500;
  cursor: pointer;
  border: none;
  width: 100%;
  transition: opacity .2s;
}

.btn-dark-solid:hover { opacity: .85; }

.btn svg, .btn-orange-outline svg {
  width: 14px;
  height: 14px;
}

/* ─── HERO ─────────────────────────────────────────────────── */
.hero {
  position: relative;
  height: 80svh;
  min-height: 850px;
  padding: 1.25rem;
  background: var(--cream-warm);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.013rem;
  overflow: hidden;
}

.hero-left {
  background: var(--orange);
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 2.4rem 2.5rem 2.5rem;
  position: relative;
  z-index: 2;
}

.hero-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hero-logo {
  color: var(--dark);
  display: flex;
  align-items: center;
}

.hero-nav-controls {
  display: flex;
  gap: 8px;
}

.hero-nav-btn {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  border: 1.5px solid var(--dark);
  background: transparent;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.05em;
  color: var(--dark);
  transition: background 0.2s, color 0.2s;
  font-family: var(--sans);
}

.hero-nav-btn:hover {
  background: var(--dark);
  color: var(--orange);
}

.hero-nav-btn svg {
  width: 16px;
  height: 16px;
  stroke: currentColor;
  fill: none;
  stroke-width: 1.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.hero-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 2.5rem 0 2rem;
}

.hero-eyebrow {
  font-size: 1rem;
  font-weight: 500;
  color: var(--dark);
  opacity: 0.85;
  margin-bottom: 1rem;
  letter-spacing: 0.01em;
}

.hero-title {
  font-family: var(--serif);
  font-size: clamp(3.8rem, 7vw, 6.5rem);
  font-weight: 300;
  color: var(--white);
  line-height: 1.0;
  letter-spacing: -0.05em;
  margin-bottom: 0;
  font-style: bold;
}

.hero-bottom {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.hero-sub {
  font-size: 1.20rem;
  font-weight: 550;
  color: var(--dark);
  line-height: 1.55;
  max-width: 500px;
  letter-spacing: 0.01rem;
}

.hero-ctas {
  display: flex;
  gap: 12px;
  flex-wrap: nowrap;
  align-items: center;
}

.btn-hero-primary {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  background: #162933;
  color: var(--white);
  border: none;
  border-radius: 100px;
  padding: 0.85rem 1.6rem;
  font-size: 1rem;
  font-weight: 500;
  cursor: pointer;
  text-decoration: none;
  transition: background 0.2s, transform 0.15s;
  font-family: var(--sans);
}

.btn-hero-primary:hover {
  background: #333;
  transform: translateY(-1px);
}

.btn-hero-primary .arrow-icon,
.arrow-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.btn-hero-primary .arrow-icon svg,
.arrow-icon svg {
  width: 12px;
  height: 12px;
  stroke: white;
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.btn-hero-secondary {
  display: inline-flex;
  align-items: center;
  background: var(--white);
  color: var(--dark);
  border: 1.5px solid var(--white);
  border-radius: 100px;
  padding: 0.85rem 1.6rem;
  font-size: 1rem;
  font-weight: 500;
  cursor: pointer;
  text-decoration: none;
  transition: background 0.2s, color 0.2s, border-color 0.2s;
  font-family: var(--sans);
}

.btn-hero-secondary:hover {
  background: var(--dark);
  color: var(--white);
  border-color: var(--dark);
}

.hero-right {
  position: relative;
  background: var(--cream-2);
  overflow: hidden;
}

.hero-right img {
  position: absolute;
  inset: 0;
  object-position: top right;
}

/* ─── SECTION: INTRO TEXT ─────────────────────────────────── */
.intro-line { display: inline; }

.intro {
  background: #f9eede;
  padding: 7rem var(--pad-x) 7rem clamp(1.6rem, 4vw, 5.6rem);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: start;
}

.intro-title {
  font-family: var(--serif);
  font-size: clamp(2.2rem, 3.5vw, 3.6rem);
  font-weight: 700;
  line-height: 1.05;
}

.intro-title em {
  color: #aaa;
  font-style: normal;
}

.intro-body {
  font-size: 1.575rem;
  font-weight: 400;
  color: #aaa;
  line-height: 1.35;
  max-width: clamp(300px, 35vw, 600px);
  margin-left: auto;
  margin-right: 0;
}

/* ─── SECTION: FULL PHOTO ─────────────────────────────────── */
.full-photo {
  height: 520px;
  overflow: hidden;
}

.full-photo img { height: 100%; }

/* ─── SECTION: NOT FINISHED ──────────────────────────────── */
.not-finished {
  background: #faefde;
  padding: 6rem clamp(2rem, 3vw, 4rem);
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
}

.nf-tag {
  font-size: .8rem;
  font-weight: 600;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 1rem;
}

.nf-title {
  font-family: var(--serif);
  font-size: clamp(2.8rem, 4.2vw, 3.92rem);
  font-weight: 700;
  line-height: 1.1;
  margin-bottom: 1.68rem;
}

.nf-title em {
  color: var(--orange);
  font-style: normal;
}

.nf-body {
  font-size: 1.34rem;
  font-weight: 400;
  color: #888;
  line-height: 1.08;
  margin-bottom: 2.8rem;
  max-width: 470px;
}

.nf-left .btn {
  font-size: 1.26rem;
  padding: 0.98rem 2.24rem;
}

.nf-left .arrow-icon svg {
  width: 17px;
  height: 17px;
}

.nf-right {
  padding-top: 2rem;
}

.nf-accordion {
  border-top: none;
}

.nf-item {
  border-bottom: none;
  padding: 1.96rem 1.2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
  border-radius: 4px;
  transition: background .15s;
}

.nf-item.open {
  background: var(--white);
  border-bottom: none;
  border-radius: 4px 4px 0 0;
}

.nf-item-inner {
  display: flex;
  align-items: center;
  gap: 1.1rem;
}

.nf-icon {
  width: 24px;
  height: 24px;
  color: var(--orange);
  flex-shrink: 0;
  object-fit: contain;
}

.nf-item-label {
  font-size: 1.47rem;
  font-weight: 600;
}

.nf-item-arrow {
  font-size: 1.1rem;
  color: var(--text);
  transition: transform .3s;
  display: inline-block;
  line-height: 1;
}

.nf-item.open .nf-item-arrow {
  transform: rotate(180deg);
}

.nf-item-body {
  font-size: .95rem;
  font-weight: 400;
  color: #9a9a9a;
  line-height: 1.7;
  padding: 0 1.2rem 0.84rem calc(24px + 1.1rem);
  background: var(--white);
  border-radius: 0 0 4px 4px;
  margin-bottom: .25rem;
}

/* ─── SECTION: DESIGNED WITH INTENTION ───────────────────── */
.intention {
  background: #ffffff;
  padding: 5rem var(--pad-x);
  text-align: center;
}

.intention .section-title {
  font-size: clamp(2.34rem, 3.64vw, 3.38rem);
}

.intention .section-sub {
  font-size: 1.17rem;
  max-width: 750px;
  line-height: 1.15;
}

.section-eyebrow {
  font-size: .75rem;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: .75rem;
}

.section-title {
  font-family: var(--serif);
  font-size: clamp(1.8rem, 2.8vw, 2.6rem);
  font-weight: 400;
  line-height: 1.15;
  margin-bottom: 1rem;
}

.section-title em {
  color: var(--orange);
  font-style: normal;
}

.section-sub {
  font-size: .9rem;
  font-weight: 400;
  color: var(--muted);
  line-height: 1.7;
  max-width: 520px;
  margin: 0 auto 3rem;
}

/* ─── GALLERY GRID ──────────────────────────────────────── */
.photo-grid {
  display: grid;
  grid-template-columns: 360fr 482fr 362fr;
  gap: 0.5rem;
  align-items: start;
  overflow: hidden;
}

.gallery-col {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.gallery-col-side {
  padding-top: 1rem;
}

.photo-grid > .gallery-col:last-child {
  padding-top: 1.5rem;
}

.gallery-col > div {
  overflow: hidden;
  border-radius: 0;
  background: var(--cream-2);
}

.gallery-col img {
  width: 100%;
  height: auto;
  display: block;
  transition: transform .4s;
}

.gallery-col > div:hover img {
  transform: scale(1.04);
}

/* mobile gallery cols — hidden on desktop */
.mob-col { display: none; }

.img-placeholder {
  width: 100%;
  height: 100%;
  background: var(--cream-2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: .7rem;
  color: var(--muted);
  text-align: center;
  padding: .5rem;
}

/* ─── SECTION: CONNECTED ──────────────────────────────────── */
.connected {
  background: #faefde;
  padding: 0;
  display: grid;
  grid-template-columns: 38% 62%;
  gap: 0;
  overflow: hidden;
}

.connected-left {
  background: #faefde;
  padding: 7.92rem 2.5rem 9rem var(--pad-x);
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-self: stretch;
  z-index: 1;
}

.connected-left .section-title {
  color: var(--text);
  margin-bottom: 1.2rem;
  font-size: clamp(3.37rem, 4.493vw, 4.493rem);
  line-height: 0.92;
  white-space: nowrap;
}

.connected-left .section-title em {
  color: var(--orange);
  font-style: normal;
}

.connected-body {
  font-size: 1.57rem;
  color: var(--muted);
  line-height: 1.155;
  max-width: 570px;
}

.map-placeholder {
  width: 100%;
  height: 813px;
  background: #faefde;
  overflow: hidden;
  position: relative;
}

.map-placeholder img {
  position: absolute;
  top: 0;
  right: 0;
  height: 100%;
  width: auto;
  max-width: none;
  display: block;
}

.connected-icons {
  background: #ffffff;
  grid-column: 1 / -1;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8.07rem;
  padding: 5.6rem var(--pad-x) 3rem;
  border-top: 1px solid #e8e0d5;
}

.ci-item {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  font-style: bold;
}

.ci-icon {
  width: 25.2px;
  height: 25.2px;
  color: var(--orange);
  flex-shrink: 0;
  margin-top: 2px;
  object-fit: contain;
}

.ci-text {
  font-size: 0.9rem;
  color: var(--muted);
  line-height: 1.5;
}

/* ─── SECTION: DISCOVER ───────────────────────────────────── */
.discover-wrap {
  padding: 4rem var(--pad-x) 5rem;
  background: #ffffff;
}

.discover {
  background: var(--orange);
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 340px;
  border-radius: 0;
  overflow: hidden;
}

.discover-left {
  padding: 4rem 0.6rem 4rem 3.5rem;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.discover-title {
  font-family: var(--serif);
  font-size: clamp(3rem, 6vw, 4.2rem);
  font-weight: 500;
  color: var(--white);
  margin-bottom: 0;
  line-height: 1.1;
  max-width: 500px;
}

.discover-bottom {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.discover-body {
  font-size: 1.4rem;
  color: var(--dark);
  line-height: 1.5;
  margin-bottom: 1rem;
  max-width: 500px;
}

.discover-ctas {
  display: flex;
  gap: .75rem;
  flex-wrap: nowrap;
}

.discover-ctas .btn { white-space: nowrap; padding: .91rem 2.08rem; font-size: 1.17rem; }

.btn-virtual-tour {
  background: white;
  color: var(--dark);
  border: 1.5px solid white;
}

.discover-right {
  padding: 0.875rem;
  display: flex;
  align-items: stretch;
}

.discover-img-wrap {
  flex: 1;
  overflow: hidden;
}

.discover-img-wrap img {
  height: 100%;
  width: 100%;
  object-fit: cover;
  object-position: center;
  border-radius: 0;
  display: block;
}

/* ─── SECTION: AVAILABLE HOMES ────────────────────────────── */
.homes {
  background: #faefde;
  padding: 5rem clamp(1rem, 3vw, 3rem);
}

.homes-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 2.5rem;
}

.homes-title {
  font-family: var(--serif);
  font-size: clamp(2.08rem, 2.86vw, 2.86rem);
  font-weight: 700;
}

.homes-desc {
  font-size: 1.038rem;
  color: #6b6b6b;
  line-height: 1.02;
  max-width: 500px;
}

.homes-filters {
  display: flex;
  gap: 2rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}

.filter-group {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: .4rem;
  align-items: center;
}

.filter-label {
  font-size: .91rem;
  font-weight: 600;
  color: var(--orange);
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--orange);
  width: 100%;
  margin-bottom: .1rem;
}

.filter-chip {
  padding: .3rem .8rem;
  border-radius: 99px;
  font-size: .94rem;
  font-weight: 500;
  border: 1.5px solid var(--cream-2);
  background: var(--white);
  color: var(--dark);
  cursor: pointer;
  transition: background .15s, color .15s, border-color .15s;
}

.filter-chip.active {
  background: var(--dark);
  color: var(--white);
  border-color: var(--dark);
}

.homes-table {
  width: 100%;
  border-collapse: collapse;
}

.homes-table thead tr {
  border-bottom: 2px solid #8a7a6a;
}

.homes-table tbody tr:not(:last-child) {
  border-bottom: 1.5px solid #746E68;
}

.homes-table th {
  text-align: left;
  font-size: .91rem;
  font-weight: 700;
  font-weight: 600;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--muted);
  padding: .66rem 2rem .26rem 0;
  border-bottom: 1.5px solid #746E68;
}

.homes-table td {
  font-size: 1.08rem;
  color: #aaa;
  padding: 1.1rem 2rem 1.1rem 0;
  vertical-align: middle;
}

.homes-table tbody tr:not(:last-child) td {
  border-bottom: 1.5px solid #746E68;
}

.homes-table td:first-child {
  font-weight: 700;
  color: var(--dark);
}

.homes-table th:last-child,
.homes-table td:last-child {
  padding-right: 0;
  text-align: left;
}

.status-badge {
  display: inline-block;
  padding: .25rem .8rem;
  border-radius: 99px;
  font-size: .91rem;
  font-weight: 500;
}

.status-badge.available {
  border: 1.5px solid var(--orange);
  color: var(--orange);
}

.status-badge.reserved {
  background: var(--dark);
  border: 1.5px solid var(--dark);
  color: var(--white);
}

.homes-note {
  font-size: .94rem;
  color: #9a9a9a;
  margin-top: 1rem;
  margin-bottom: 2.63rem;
}

.homes-table .last-row td {
  border-bottom: none !important;
}

/* ─── SECTION: WHAT BLOOM OFFERS ─────────────────────────── */
.offers {
  background: #ffffff;
  padding: 5rem 0;
  text-align: center;
}

.offers .container {
  padding-left: 0;
  padding-right: 0;
}

.offers .section-title {
  font-size: clamp(2.7rem, 4.2vw, 3.9rem);
}

.offers .section-sub {
  font-size: 1.35rem;
  max-width: 450px;
  line-height: 1.02;
  color: #9a9a9a;
}

.offers-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 5rem;
  margin-top: 6rem;
  margin-left: -1.5rem;
  margin-right: -1.5rem;
  text-align: left;
}

.offer-icon {
  width: 24px;
  height: 24px;
  color: var(--orange);
  margin-bottom: 1rem;
  object-fit: contain;
  display: block;
}

.offer-title {
  font-size: 1.105rem;
  font-weight: 600;
  margin-bottom: .5rem;
}

.offer-body {
  font-size: 1.014rem;
  color: #9a9a9a;
  line-height: 1.7;
}

/* ─── SECTION: PLOTS FOR SALE ─────────────────────────────── */
.section-divider-orig {
  background: #faefde;
  padding: 0 var(--pad-x);
}

.section-divider-orig::after {
  content: '';
  display: block;
  height: 2.25px;
  background: rgba(0,0,0,0.22);
}

.plots-section {
  padding: 5rem 3rem;
  background: #faefde;
}

.plots-section h2 {
  font-family: var(--serif);
  font-size: clamp(3rem, 6vw, 6rem);
  font-weight: 400;
  margin-bottom: 1rem;
}

.plots-section > p {
  color: var(--muted);
  max-width: 672px;
  line-height: 1.7;
  margin-bottom: 2.5rem;
  font-size: 1.35rem;
}

.plots-img-wrap { position: relative; }

.aerial-img {
  width: 100%;
  height: 520px;
  border-radius: 12px;
  overflow: hidden;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 12px;
  background: linear-gradient(135deg, #8fa8a4 0%, #6d8e8a 100%);
}

.aerial-badge {
  position: absolute;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  white-space: nowrap;
  width: 76px;
